{% extends "generic_show_form.html.twig" %}
{% import "components/form/fields_macros.html.twig" as fields %}

{% block more_fields %}

    {# Injection des données pour le JS externe (public/account.form.js) #}
    <script>
    window.dnsmanagerData = {
        allProviderData:     {{ allProviderData|raw }},
        existingCredentials: {{ credentials|raw }},
        currentEndpoint:     '{{ currentEndpoint }}',
        accountId:           {{ item.fields['id'] ?? 0 }}
    };
    </script>

    {{ fields.smallTitle(__('Informations générales', 'dnsmanager')) }}

    {# Provider #}
    <div class="mb-3 row">
        <label class="col-xxl-4 col-form-label">{{ __('Provider', 'dnsmanager') }} *</label>
        <div class="col-xxl-8">
            <select name="provider_type" id="dns-provider-select" class="form-select" required>
                <option value="" {% if not item.fields['provider_type'] %}selected{% endif %} disabled>
                    -- {{ __('Choisir un provider', 'dnsmanager') }} --
                </option>
                {% for type, label in providers %}
                    <option value="{{ type }}" {% if item.fields['provider_type'] == type %}selected{% endif %}>
                        {{ label }}
                    </option>
                {% endfor %}
            </select>
        </div>
    </div>

    {# Champs masqués pour l'Observateur - valeur passée par showForm() #}
    {% set is_observer = not can_sync %}

    {% if not is_observer %}
        {# Endpoint #}
        <div class="mb-3 row" id="dns-endpoint-section">
            <label class="col-xxl-4 col-form-label">{{ __('Endpoint / Région', 'dnsmanager') }} *</label>
            <div class="col-xxl-8">
                <select name="endpoint" id="dns-endpoint-select" class="form-select" required>
                    <option value="" selected disabled>-- {{ __('Choisir un endpoint', 'dnsmanager') }} --</option>
                </select>
            </div>
        </div>
    {% endif %}

    {{ fields.dropdownField('Supplier', 'suppliers_id', item.fields['suppliers_id'], __('Fournisseur', 'dnsmanager'), {
        'display_emptychoice': true,
        'emptylabel': '-- ' ~ __('Choisir un fournisseur', 'dnsmanager') ~ ' --',
        'readonly': is_observer
    }) }}

    {% if not is_observer %}

        {{ fields.textField('domain_whitelist', item.fields['domain_whitelist'], __('Liste blanche des domaines', 'dnsmanager'), {
            'helper': __("Domaines séparés par virgules. Vide = tous les domaines éligibles.", 'dnsmanager')
        }) }}

        {{ fields.numberField('renewal_months', item.fields['renewal_months'] ?? 1, __('Préavis de facturation (mois)', 'dnsmanager'), {
            'min': 1, 'max': 12
        }) }}

        {{ fields.smallTitle(__("Contacts par défaut (copiés à l'import)", "dnsmanager")) }}

        {# Groupe et Groupe responsable sont gérés automatiquement par GLPI dans l'en-tête #}
        {# Ils sont mémorisés via groups_id et groups_id_tech dans la table du compte #}

        {% if accounts_class %}
        {{ fields.dropdownField(
            accounts_class,
            'plugin_accounts_accounts_id_administrateurfield',
            item.fields['plugin_accounts_accounts_id_administrateurfield'] ?? 0,
            __('Administrateur', 'dnsmanager'),
            {'display_emptychoice': true}
        ) }}

        {{ fields.dropdownField(
            accounts_class,
            'plugin_accounts_accounts_id_technicienfield',
            item.fields['plugin_accounts_accounts_id_technicienfield'] ?? 0,
            __('Technicien', 'dnsmanager'),
            {'display_emptychoice': true}
        ) }}

        {{ fields.dropdownField(
            accounts_class,
            'plugin_accounts_accounts_id_financierfield',
            item.fields['plugin_accounts_accounts_id_financierfield'] ?? 0,
            __('Financier', 'dnsmanager'),
            {'display_emptychoice': true}
        ) }}
        {% else %}
        <div class="alert alert-warning">
            <i class="ti ti-alert-triangle me-2"></i>{{ __('Plugin Accounts requis pour les contacts.', 'dnsmanager') }}
        </div>
        {% endif %}

        {{ fields.dropdownField(
            'User',
            'users_id_proprietairefield',
            item.fields['users_id_proprietairefield'] ?? 0,
            __('Propriétaire', 'dnsmanager'),
            {'display_emptychoice': true, 'right': 'all'}
        ) }}

        {{ fields.smallTitle(__('Authentification', 'dnsmanager')) }}

        <div id="dns-credentials-section" class="col-12 mb-3">
            <div class="alert alert-info"><i class="ti ti-loader me-2"></i>Chargement...</div>
        </div>

        {% if item.fields['id'] > 0 %}
        <div class="col-12 mb-3 d-flex gap-2 flex-wrap">
            <button type="button" id="dns-btn-test" class="btn btn-primary">
                <i class="ti ti-plug me-1"></i>{{ __('Tester la connexion', 'dnsmanager') }}
            </button>
            <a href="{{ webdir }}/front/domain.import.php?account_id={{ item.fields['id'] }}"
               class="btn btn-primary" id="dns-btn-sync-interactive">
                <i class="ti ti-world-upload me-1"></i>{{ __('Analyser et synchroniser', 'dnsmanager') }}
            </a>
            <button type="button" id="dns-btn-sync" class="btn btn-primary">
                <i class="ti ti-refresh me-1"></i>{{ __('Sync rapide', 'dnsmanager') }}
            </button>
        </div>
        {% endif %}
        <div id="dns-action-result" class="col-12 mb-3"></div>

    {% else %}
        <div class="alert alert-info mt-2">
            <i class="ti ti-info-circle me-2"></i>{{ __("Accès en lecture seule.", "dnsmanager") }}
        </div>
    {% endif %}

{% endblock more_fields %}
